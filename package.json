{
  "name": "walnut",
  "version": "0.1.0",
  "description": "Personal intelligent butler - CLI task manager",
  "type": "module",
  "bin": {
    "walnut": "./bin/walnut.js"
  },
  "main": "./dist/cli.js",
  "scripts": {
    "postinstall": "cd web && npm install",
    "start": "npm run web:build && node dist/cli.js web --port 3456",
    "build": "tsup && cp -r src/data dist/",
    "dev": "tsup --watch",
    "test": "node scripts/test-parallel.mjs",
    "test:unit": "vitest run --config vitest.unit.config.ts",
    "test:integration": "vitest run --config vitest.integration.config.ts",
    "test:e2e": "vitest run --config vitest.e2e.config.ts",
    "test:live": "WALNUT_LIVE_TEST=1 vitest run --config vitest.live.config.ts",
    "test:all": "npm run lint && npm run test && npx playwright test",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest",
    "lint": "tsc --noEmit",
    "web": "node dist/web/server.js",
    "web:dev": "concurrently \"tsup --watch\" \"cd web && npx vite\"",
    "web:build": "tsup && cd web && npx vite build",
    "dev:ephemeral": "npm run web:build && node dist/cli.js web --ephemeral",
    "dev:prod": "npm run web:build && lsof -ti:3456 | xargs kill -15 2>/dev/null; sleep 2; node dist/cli.js web --port 3456"
  },
  "dependencies": {
    "@anthropic-ai/bedrock-sdk": "^0.26.3",
    "@anthropic-ai/claude-agent-sdk": "^0.2.42",
    "@anthropic-ai/tokenizer": "^0.0.4",
    "@azure/msal-node": "^5.0.3",
    "@mozilla/readability": "^0.6.0",
    "@slack/web-api": "^7.14.0",
    "better-sqlite3": "^12.6.2",
    "chalk": "^5.4.1",
    "commander": "^14.0.0",
    "cors": "^2.8.6",
    "croner": "^10.0.1",
    "express": "^5.2.1",
    "image-size": "^2.0.2",
    "js-yaml": "^4.1.0",
    "linkedom": "^0.18.12",
    "marked": "^15.0.12",
    "marked-terminal": "^7.3.0",
    "sharp": "^0.34.5",
    "ws": "^8.19.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@types/better-sqlite3": "^7.6.13",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/image-size": "^0.7.0",
    "@types/js-yaml": "^4.0.9",
    "@types/marked-terminal": "^6.1.1",
    "@types/node": "^22.15.0",
    "@types/sharp": "^0.31.1",
    "@types/supertest": "^6.0.3",
    "@types/ws": "^8.18.1",
    "@vitest/coverage-v8": "^3.1.0",
    "concurrently": "^9.2.1",
    "supertest": "^7.2.2",
    "tsup": "^8.5.0",
    "typescript": "^5.8.0",
    "vitest": "^3.1.0"
  }
}
